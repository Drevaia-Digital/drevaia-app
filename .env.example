# ============================================
# BREVO EMAIL MARKETING CONFIGURATION
# ============================================
# 1. Ve a https://app.brevo.com/settings/keys/api
# 2. Crea una nueva API Key (tipo "Marketing")
# 3. Copia la API Key y pégala aquí

VITE_BREVO_API_KEY=tu_api_key_aqui

# ============================================
# BREVO LIST ID (Opcional)
# ============================================
# 1. Ve a https://app.brevo.com/contact/list
# 2. Crea una lista o selecciona una existente
# 3. Copia el ID de la lista (número)

VITE_BREVO_LIST_ID=12345678

# ============================================
# INSTRUCCIONES DE CONFIGURACIÓN
# ============================================
# 1. Renombra este archivo a ".env"
# 2. Reemplaza los valores con tus credenciales reales
# 3. Reinicia el servidor de desarrollo
# 4. Los datos del formulario se enviarán automáticamente a Brevo
#
# IMPORTANTE: Nunca subas el archivo .env a GitHub (ya está en .gitignore)
